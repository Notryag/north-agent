OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
APP_MODEL_NAME=openai:gpt-4o-mini
APP_THINKING_ENABLED=false
APP_SYSTEM_PROMPT=You are a concise assistant.
APP_RECURSION_LIMIT=50

# Optional host path overrides. The example CLI otherwise uses ./skills and ./.deerflow.
# APP_SKILLS_DIR=/absolute/path/to/skills
# APP_THREAD_BASE_DIR=/absolute/path/to/runtime-data

# Optional: LangSmith tracing / observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=north-agent
